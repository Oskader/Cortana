# ═══════════════════════════════════════════════════════════
# CORTANA TRADING BOT 2026 — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ─── ALPACA MARKETS ───
# Obtener en: https://app.alpaca.markets → Account → API Keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── GROQ AI ───
# Obtener en: https://console.groq.com → API Keys
GROQ_API_KEY=
# Modelo recomendado para análisis complejo (Ej: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
# Confidence mínima final asignada por la IA para ejecutar un trade (0.0 - 10.0 SMC Score):
GROQ_MIN_SCORE=7.0
# Timeout máximo por llamada en segundos:
GROQ_TIMEOUT=20

# ─── TELEGRAM ───
# Crear bot en @BotFather y obtener token
TELEGRAM_TOKEN=
# Tu chat ID (obtener con @userinfobot)
TELEGRAM_CHAT_ID=
# IDs adicionales separados por coma (opcional):
# ALLOWED_CHAT_IDS=123456,789012

# ─── NEWS API ───
# Obtener en: https://newsapi.org (opcional, el bot funciona sin esto)
NEWS_API_KEY=

# ─── RISK & CAPITAL MANAGEMENT ───
# "paper" para simulación, "live" para dinero real
TRADING_MODE=paper
# Tamaño máximo de posición como % del portfolio (Ej. 20% para cuenta de $10 = 0.20):
MAX_POSITION_SIZE_PCT=0.20
# Cojín de liquidez intocable (10% = 0.10)
LIQUIDITY_CUSHION_PCT=0.10
# Pérdida diaria máxima antes de detener trading (1.5% = 0.015):
MAX_DAILY_LOSS_PCT=0.015
# Drawdowns que causan PAUSE / HALT (-15% y -25%):
DRAWDOWN_PAUSE_PCT=-0.15
DRAWDOWN_HALT_PCT=-0.25
# Número máximo de posiciones abiertas simultáneamente (Max 2 de cuenta chica):
MAX_OPEN_POSITIONS=2

# ─── STRATEGY & DYNAMIC SCREENING ───
# En lugar de hardcoded watchlist, Cortana escanea el mercado. Si quieres un fallback o base_universe:
WATCHLIST_SYMBOLS=AAPL,MSFT,GOOGL,NVDA,META,AMZN,TSLA,NFLX,AMD,COIN

# ─── MARKET HOURS (Eastern Time) ───
# Inicio de operaciones (evita volatilidad de apertura: 9:45 AM ET)
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=45
# Fin de operaciones (asegura cierres a tiempo: 3:45 PM ET)
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=45

# ─── INFRASTRUCTURE ───
DATABASE_URL=sqlite:///data/trading_bot.db
LOG_LEVEL=INFO
# TTL del cache de datos en segundos:
CACHE_TTL_SECONDS=60
