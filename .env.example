# ═══════════════════════════════════════════════════════════
# CORTANA TRADING BOT — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ─── ALPACA MARKETS ───
# Obtener en: https://app.alpaca.markets → Account → API Keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── GROQ AI ───
# Obtener en: https://console.groq.com → API Keys
GROQ_API_KEY=
# Modelo recomendado para análisis complejo:
GROQ_MODEL=llama-3.3-70b-versatile
# Confidence mínima para ejecutar un trade (0.0 - 1.0):
GROQ_MIN_CONFIDENCE=0.72
# Timeout máximo por llamada en segundos:
GROQ_TIMEOUT=15

# ─── TELEGRAM ───
# Crear bot en @BotFather y obtener token
TELEGRAM_TOKEN=
# Tu chat ID (obtener con @userinfobot)
TELEGRAM_CHAT_ID=
# IDs adicionales separados por coma (opcional):
# ALLOWED_CHAT_IDS=123456,789012

# ─── NEWS API ───
# Obtener en: https://newsapi.org (opcional, el bot funciona sin esto)
NEWS_API_KEY=

# ─── TRADING PARAMETERS ───
# "paper" para simulación, "live" para dinero real
TRADING_MODE=paper
# Pérdida diaria máxima antes de detener trading (2% = 0.02):
MAX_DAILY_LOSS_PCT=0.02
# Tamaño máximo de posición como % del portfolio (5% = 0.05):
MAX_POSITION_SIZE_PCT=0.05
# Número máximo de posiciones abiertas simultáneamente:
MAX_OPEN_POSITIONS=5
# Número máximo de trades por día (PDT protection):
MAX_DAILY_TRADES=3

# ─── WATCHLIST ───
# Símbolos separados por coma:
WATCHLIST_SYMBOLS=AAPL,MSFT,GOOGL,NVDA,META,AMZN,TSLA,NFLX,AMD,COIN

# ─── MARKET HOURS (Eastern Time) ───
# Inicio de operaciones (default: 9:35 AM ET, evita los primeros 5 min)
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=35
# Fin de operaciones (default: 3:50 PM ET, evita los últimos 10 min)
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=50

# ─── INFRASTRUCTURE ───
# URL de la base de datos SQLite:
DATABASE_URL=sqlite:///data/trading_bot.db
# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# TTL del cache de datos de mercado en segundos:
CACHE_TTL_SECONDS=60
